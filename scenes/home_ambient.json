{
    "name": "home_ambient",
    "description": "Chill: blue wash, pattern LEDs breathe with the mids, no spin/laser/strobe, ball drifts blue",
    "key_command": "1",
    "midi": 60,
    "lights": [
        {
            "name": "partylight",
            "type": "partylight",
            "modulator": "mfft",
