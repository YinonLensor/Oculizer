            "color": "blue",
            "pattern": "audio",
            "pattern_spin": 0,
            "laser_color": "off",
            "laser_spin": 0,
            "strobe": 0
        },
        {
            "name": "discoball",
            "type": "discoball",
            "modulator": "time",
            "frequency": 0.08,
            "function": "sine",
            "min_brightness": 110,
            "max_brightness": 200,
            "color": "blue",
            "strobe": 0
        }
    ]
}
